# Copy to .env and fill in values before first start
API_KEY=
WEB_PORT=3003

# --- Admin CMS (gutafinn_cms), served at https://gutafinn-admin.tobtech.se ---
# Single-level subdomain of tobtech.se (not admin.gutafinn.tobtech.se) so it's
# covered by the free Universal SSL wildcard (*.tobtech.se) instead of requiring
# Total TLS / paid Advanced Certificate Manager for a nested subdomain.
# Required:
ADMIN_PASSWORD=
SESSION_SECRET=                                 # at least 32 random characters
# Passkeys — RP id is the exact CMS hostname:
PASSKEY_RP_ID=gutafinn-admin.tobtech.se
PASSKEY_ORIGIN=https://gutafinn-admin.tobtech.se
PASSKEY_RP_NAME=Gutafinn CMS
SECURE_COOKIES=true
# Set only while enrolling new admins, then clear it and redeploy:
SIGNUP_CODE=
