# Copy to .env and fill in values before first start
API_KEY=
WEB_PORT=3003

# --- Admin CMS (gutafinn_cms), served at https://admin.gutafinn.tobtech.se ---
# Required:
ADMIN_PASSWORD=
SESSION_SECRET=                                 # at least 32 random characters
# Passkeys — RP id is the parent domain so subdomain credentials validate:
PASSKEY_RP_ID=gutafinn.tobtech.se
PASSKEY_ORIGIN=https://admin.gutafinn.tobtech.se
PASSKEY_RP_NAME=Gutafinn CMS
SECURE_COOKIES=true
# Set only while enrolling new admins, then clear it and redeploy:
SIGNUP_CODE=
